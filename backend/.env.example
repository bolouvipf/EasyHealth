# EasyHealth Backend — Exemple de configuration
# Copier vers .env et remplacer les secrets

NODE_ENV=development
PORT=3000

# JWT — changer impérativement en production
JWT_SECRET=votre-secret-jwt-tres-long-et-complexe
JWT_EXPIRATION=15m

# BDD
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=votre-mot-de-passe
DB_DATABASE=easyhealth

# Pour développement SQLite :
# DB_TYPE=sqlite
# DB_PATH=./data/easyhealth.db

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Chiffrement AES-256 (clé de 32 caractères)
ENCRYPTION_KEY=votre-cle-de-32-caracteres-ici!!
