{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://easyhealth-api.onrender.com/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "installCommand": "npm install",
  "rootDirectory": "frontend"
}
